SUPABASE_PROJECT_ID=your_project_id
SUPABASE_API_URL=https://your_project_id.supabase.co
SUPABASE_SECRET_KEY=your_secret_key
# Required for POST /api/auth/login and /api/auth/refresh (GoTrue password grant). Not exposed to the browser.
SUPABASE_ANON_KEY=your_anon_key

# Supabase HTTP (undici): TCP connect timeout defaults to 10s in Node without this.
# SUPABASE_CONNECT_TIMEOUT_MS=45000
# Headers / body timeouts for the TLS + response (ms).
# SUPABASE_HEADERS_TIMEOUT_MS=120000
# SUPABASE_BODY_TIMEOUT_MS=120000
# Overall AbortSignal ceiling for each Supabase fetch (ms).
# SUPABASE_FETCH_TIMEOUT_MS=60000
# Auth middleware: extra getUser attempts when errors look like transient network (0–4, default 2).
# SUPABASE_AUTH_GET_USER_RETRIES=2

# Backend server
PORT=3001
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# HTTP trace: logs [http] … for each request/response (sanitized bodies). Set 0 to disable.
# REQUEST_TRACE=0

# Groq AI
GROQ_API_KEY=your_groq_api_key
