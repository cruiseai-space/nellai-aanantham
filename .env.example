SUPABASE_PROJECT_ID=your_project_id
SUPABASE_API_URL=https://your_project_id.supabase.co
SUPABASE_SECRET_KEY=your_secret_key
# Required for POST /api/auth/login and /api/auth/refresh (GoTrue password grant). Not exposed to the browser.
SUPABASE_ANON_KEY=your_anon_key

# Backend server
PORT=3001
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# HTTP trace: logs [http] … for each request/response (sanitized bodies). Set 0 to disable.
# REQUEST_TRACE=0

# Groq AI
GROQ_API_KEY=your_groq_api_key
